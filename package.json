{
  "name": "reknotes",
  "version": "0.1.0",
  "description": "Personal knowledge management with auto-organization and fast search",
  "type": "module",
  "scripts": {
    "setup": "bun install && bun run build && bun run lib/setup.ts && NODE_ENV=development bun run migrate && NODE_ENV=test bun run migrate",
    "build": "bun run lib/build.ts",
    "dev": "bun run build && bun run --watch src/index.ts",
    "migrate": "bun run lib/migrate.ts",
    "seed": "bun run lib/seed.ts",
    "check": "bunx biome check --write && bunx tsc --noEmit",
    "test": "NODE_ENV=test bun test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@huggingface/transformers": "^3.8.1",
    "cytoscape": "^3.33.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0",
    "htmx.org": "^2.0.8",
    "liquidjs": "^10.21.0",
    "postgres": "^3.4.8",
    "zenn-content-css": "^0.4.6",
    "zenn-markdown-html": "^0.1.162"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "trustedDependencies": [
    "esbuild",
    "onnxruntime-node",
    "protobufjs"
  ]
}
