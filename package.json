{
  "name": "reknotes",
  "version": "0.1.0",
  "description": "Personal knowledge management with auto-organization and fast search",
  "type": "module",
  "scripts": {
    "setup": "bun install && bun run build && bun run lib/setup.ts && ENVIRONMENT=development bun run migrate -- --apply && ENVIRONMENT=test bun run migrate -- --apply",
    "build": "bun run lib/build.ts",
    "dev": "bun run build && bun run --watch src/index.ts",
    "migrate": "bun run lib/migration/migrate.ts",
    "seed": "bun run lib/seed.ts",
    "check": "bunx biome check --write && bunx tsc --noEmit",
    "test": "ENVIRONMENT=test bun test"
  },
  "dependencies": {
    "3d-force-graph": "^1.79.1",
    "@aws-sdk/client-s3": "^3.1019.0",
    "@huggingface/transformers": "^3.8.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0",
    "htmx.org": "^2.0.8",
    "liquidjs": "^10.21.0",
    "postgres": "^3.4.8",
    "zenn-content-css": "^0.4.6",
    "zenn-markdown-html": "^0.1.162"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "trustedDependencies": [
    "esbuild",
    "onnxruntime-node",
    "protobufjs"
  ]
}
