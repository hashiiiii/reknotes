{
  "name": "reknotes",
  "version": "0.1.0",
  "description": "Personal knowledge management with auto-organization and fast search",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "migrate": "bunx drizzle-kit push --force",
    "seed": "bun run lib/seed.ts",
    "check": "bunx biome check --write && bunx tsc --noEmit",
    "test": "rm -f data/test.sqlite && DB_PATH=data/test.sqlite bun run migrate && DB_PATH=data/test.sqlite bun test"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0",
    "liquidjs": "^10.21.0",
    "zenn-content-css": "^0.4.6",
    "zenn-markdown-html": "^0.1.162"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest",
    "better-sqlite3": "^12.8.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "esbuild",
    "onnxruntime-node",
    "protobufjs"
  ]
}
