# Local development defaults. `bun run setup` copies this to .env.
ENVIRONMENT=development
DEPLOYMENT=local
DATABASE_URL=postgresql://reknotes:reknotes@localhost:5432

# Object storage (MinIO via compose.local.yaml)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=reknotes
S3_SECRET_ACCESS_KEY=reknotes
S3_BUCKET_NAME=reknotes

# (optional) Backup. Only needed for `bun run dump` / `bun run restore` and the
# compose.local.yaml `backup` profile. See docs/BACKUP.md.
# BACKUP_S3_ENDPOINT=http://localhost:9002
# BACKUP_S3_ACCESS_KEY_ID=reknotes-backup
# BACKUP_S3_SECRET_ACCESS_KEY=reknotes-backup
# BACKUP_S3_BUCKET_NAME=reknotes-backup

# Remote-only variables (CLOUDFLARE_*, OAUTH2_PROXY_*, DOMAIN, GITHUB_REPOSITORY)
# are not used in local mode. They are assembled by deploy.yml from GitHub Secrets.
# See docs/INFRASTRUCTURE.md.
