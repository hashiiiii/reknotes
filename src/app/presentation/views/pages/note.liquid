{% layout 'base' %}
{% block content %}
<article class="note-detail" id="note-view">
  <header>
    <div class="note-header-row">
      <h1>{{ note.title | default: "無題" }}</h1>
      <div class="kebab-menu">
        <button class="kebab-btn" aria-label="メニュー" onclick="toggleKebab(this)">&#x22EE;</button>
        <div class="kebab-dropdown">
          <button onclick="this.closest('.kebab-menu').classList.remove('open'); enterEditMode()">編集</button>
          <button class="danger" hx-delete="/api/notes/{{ note.id }}" hx-confirm="本当に削除しますか？" hx-target="body">削除</button>
        </div>
      </div>
    </div>
    <time datetime="{{ note.createdAt }}">{{ note.createdAt | formatDate }}</time>
  </header>

  <div class="note-body znc">{{ bodyHtml }}</div>
</article>

<article class="note-detail" id="note-edit" hidden>
  <header>
    <h1>編集</h1>
  </header>
  <form hx-put="/api/notes/{{ note.id }}" hx-target="body">
    <input type="text" name="title" value="{{ note.title }}" placeholder="タイトル" class="input-title">
    <textarea name="body" rows="15" class="input-body">{{ note.body }}</textarea>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">保存</button>
      <button type="button" class="btn" onclick="exitEditMode()">キャンセル</button>
    </div>
  </form>
</article>

{% if graphData %}
  <section class="mini-graph" id="note-graph">
    <h3>Graph</h3>
    <div id="mini-graph-container"></div>
    <script src="/static/js/cytoscape.min.js"></script>
    <script src="/static/js/graph-common.js"></script>
    <script>
      window.__reknotesMiniGraphData = {{ graphData }};
      window.__reknotesCurrentNoteId = 'note-{{ note.id }}';
    </script>
  </section>
{% endif %}
<script src="/static/js/note.js"></script>
{% endblock %}
