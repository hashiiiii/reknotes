<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} - {% endif %}reknotes</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@700&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/zenn.css">
  <link rel="stylesheet" href="/static/css/style.css">
  <script src="/static/js/htmx.js"></script>
  <script>
    (function(){var t=localStorage.getItem('theme');if(t)document.documentElement.setAttribute('data-theme',t);})();
  </script>
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-brand">reknotes</a>
      <div class="nav-search">
        <input
          type="search"
          name="q"
          placeholder="検索"
          class="nav-search-input"
          hx-get="/api/search"
          hx-trigger="input changed delay:300ms, search"
          hx-target="#note-grid"
          hx-swap="innerHTML"
          {% if currentPath != "/" %}disabled{% endif %}
        >
      </div>
      <div class="nav-links">
        <a href="/" data-text="Home" {% if currentPath == "/" %}class="active"{% endif %}>Home</a>
        <a href="/graph" data-text="Graph" {% if currentPath == "/graph" %}class="active"{% endif %}>Graph</a>
        <button class="theme-toggle" id="theme-toggle" aria-label="テーマ切替"></button>
      </div>
    </div>
  </nav>
  <main class="{{ containerClass | default: 'container' }}">
    {% block content %}{% endblock %}
  </main>
  <script src="/static/js/app.js"></script>
</body>
</html>
