<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} - {% endif %}reknotes</title>
  <link rel="stylesheet" href="/static/css/zenn.css">
  <link rel="stylesheet" href="/static/css/style.css">
  <script src="/static/js/htmx.min.js"></script>
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-brand">reknotes</a>
      <div class="nav-links">
        <a href="/" {% if currentPath == "/" %}class="active"{% endif %}>Home</a>
        <a href="/search" {% if currentPath == "/search" %}class="active"{% endif %}>Search</a>
        <a href="/graph" {% if currentPath == "/graph" %}class="active"{% endif %}>Map</a>
        <a href="/tags" {% if currentPath == "/tags" %}class="active"{% endif %}>Tags</a>
      </div>
    </div>
  </nav>
  <main class="container">
    {% block content %}{% endblock %}
  </main>
</body>
</html>
